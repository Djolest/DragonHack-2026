CAPTURE_APP_NAME=oakproof-capture
CAPTURE_APP_ENV=development
CAPTURE_HOST=127.0.0.1
CAPTURE_PORT=8100
CAPTURE_LOG_LEVEL=INFO
CAPTURE_STORAGE_ROOT=data
CAPTURE_PUBLIC_BASE_URL=http://127.0.0.1:8100
CAPTURE_BACKEND_BASE_URL=http://127.0.0.1:8000
CAPTURE_CORS_ALLOW_ORIGINS=*
CAPTURE_STATION_ID=oak4-station
CAPTURE_STATION_SIGNER_PRIVATE_KEY=
CAPTURE_SIMULATE=true
CAPTURE_OAK_DEVICE_ID=
CAPTURE_AUTO_SUBMIT_TO_BACKEND=true
CAPTURE_RECEIPT_NAMESPACE=oakproof
CAPTURE_REQUEST_TIMEOUT_SECONDS=20
CAPTURE_VERIFICATION_CONFIG_PATH=config/anti_replay_thresholds.json
CAPTURE_RUNTIME_FPS=20.0
CAPTURE_RUNTIME_RGB_WIDTH=1280
CAPTURE_RUNTIME_RGB_HEIGHT=960
CAPTURE_RUNTIME_STEREO_WIDTH=1280
CAPTURE_RUNTIME_STEREO_HEIGHT=800
CAPTURE_RUNTIME_SYNC_THRESHOLD_MS=50
CAPTURE_SESSION_START_TIMEOUT_SECONDS=10.0
CAPTURE_SESSION_STOP_TIMEOUT_SECONDS=20.0
