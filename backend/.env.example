BACKEND_FLARE_CHAIN_ID=114
BACKEND_FLARE_EXPLORER_BASE_URL=https://coston2-explorer.flare.network
BACKEND_ANCHOR_CONTRACT_ADDRESS=
BACKEND_ANCHOR_PRIVATE_KEY=
BACKEND_ANCHOR_ON_INGEST=true
BACKEND_ANCHOR_GAS_LIMIT=350000
BACKEND_ANCHOR_TIMEOUT_SECONDS=180
