BACKEND_APP_NAME=oakproof-backend
BACKEND_APP_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=INFO
BACKEND_STORAGE_ROOT=data
BACKEND_CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
BACKEND_CAPTURE_SIGNER_ALLOWLIST=
